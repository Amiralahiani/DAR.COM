@model IEnumerable<RealEstateAdmin.Models.SaleTransaction>

@{
    ViewData["Title"] = "Gestion des ventes";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-gradient">
            <i class="bi bi-cash-stack"></i> Gestion des ventes
        </h1>
        <div class="d-flex gap-2">
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-journal-plus"></i> Saisie manuelle
            </a>
            <a asp-action="ExportCsv" class="btn btn-outline-primary">
                <i class="bi bi-filetype-csv"></i> CSV
            </a>
            <a asp-action="ExportPdf" class="btn btn-outline-primary">
                <i class="bi bi-file-earmark-pdf"></i> PDF
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="stat-card primary">
                <h2 class="stat-number">@ViewBag.TotalSales</h2>
                <p class="stat-label">Transactions</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card success">
                <h2 class="stat-number">@ViewBag.TotalAmount DT</h2>
                <p class="stat-label">Montant total</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card warning">
                <h2 class="stat-number">@ViewBag.PaidAmount DT</h2>
                <p class="stat-label">Montant payé</p>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Modalité de paiement</label>
                    <select class="form-select" name="paymentMethod">
                        <option value="">Toutes</option>
                        @foreach (var method in (string[])ViewBag.PaymentMethods)
                        {
                            <option value="@method" selected="@(ViewBag.PaymentMethod == method)">@method</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Statut de paiement</label>
                    <select class="form-select" name="paymentStatus">
                        <option value="">Tous</option>
                        @foreach (var status in (string[])ViewBag.PaymentStatuses)
                        {
                            <option value="@status" selected="@(ViewBag.PaymentStatus == status)">@status</option>
                        }
                    </select>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary me-2">Filtrer</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Réinitialiser</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Bien Immobilier</th>
                        <th>Acheteur / Vendeur</th>
                        <th>Montant</th>
                        <th>Statut Bien</th>
                        <th>Paiement</th>
                        <th>Date</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><span class="text-muted small">#@item.Id</span></td>
                            <td>
                                <div class="fw-bold">@(item.BienImmobilier?.Titre ?? "Bien supprimé")</div>
                                <div class="small text-muted"><i class="bi bi-geo-alt"></i> @(item.BienImmobilier?.Adresse ?? "-")</div>
                            </td>
                            <td>
                                <div class="small"><strong>Ach:</strong> @(item.Buyer?.Nom ?? item.Buyer?.Email ?? "N/A")</div>
                                <div class="small text-muted"><strong>Ven:</strong> @(item.Seller?.Nom ?? item.Seller?.Email ?? "N/A")</div>
                            </td>
                            <td>
                                <span class="fw-bold text-dark">@item.Amount.ToString("N2") DT</span>
                            </td>
                            <td>
                                @if (item.BienImmobilier?.StatutCommercial == "Vendu")
                                {
                                    <span class="badge bg-danger rounded-pill">Vendu</span>
                                }
                                else if (item.BienImmobilier?.StatutCommercial == "En cours de vente")
                                {
                                    <span class="badge bg-warning text-dark rounded-pill">En cours</span>
                                }
                                else
                                {
                                    <span class="badge bg-success rounded-pill">Disponible</span>
                                }
                            </td>
                            <td>
                                @{
                                    var badgeClass = item.StatutPaiementDetaille switch
                                    {
                                        "Complet" => "bg-success",
                                        "Partiel" => "bg-info text-dark",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @badgeClass rounded-pill">@item.StatutPaiementDetaille</span>
                                <div class="small text-muted mt-1">@item.PaymentMethod</div>
                            </td>
                            <td>
                                <div class="small">@item.CreatedAt.ToString("dd/MM/yyyy")</div>
                            </td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Détails & Contrat">
                                    <i class="bi bi-eye"></i> Gérer
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
