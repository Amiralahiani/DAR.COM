@model IEnumerable<RealEstateAdmin.Models.UserRoleViewModel>

@{
    ViewData["Title"] = "Liste des utilisateurs";
    var isSuperAdmin = User.IsInRole("SuperAdmin");
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-gradient">
            <i class="bi bi-people"></i> Liste des utilisateurs
        </h1>
        <div class="d-flex gap-2">
            @if (isSuperAdmin)
            {
                <a asp-controller="Account" asp-action="ManageRoles" class="btn btn-outline-primary">
                    <i class="bi bi-shield-check"></i> Gérer les rôles
                </a>
                <a asp-action="Create" class="btn btn-primary">
                    <i class="bi bi-person-plus"></i> Créer un compte
                </a>
            }
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model.Any())
    {
        <div class="card">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Nom</th>
                            <th>Email</th>
                            <th>Rôle</th>
                            <th>Email confirmé</th>
                            <th>État</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.UserName</td>
                                <td>@item.Email</td>
                                <td>
                                    <span class="badge bg-@(item.CurrentRole == "SuperAdmin" ? "dark" : item.CurrentRole == "Admin" ? "danger" : "primary")">
                                        @item.CurrentRole
                                    </span>
                                </td>
                                <td>
                                    @if (item.EmailConfirmed)
                                    {
                                        <span class="badge bg-success">Oui</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">Non</span>
                                    }
                                </td>
                                <td>
                                    @if (item.IsSuspended)
                                    {
                                        <span class="badge bg-danger">Suspendu</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Actif</span>
                                    }
                                </td>
                                <td class="d-flex gap-2">
                                    <a asp-action="Details" asp-route-id="@item.UserId" class="btn btn-sm btn-info">
                                        <i class="bi bi-eye"></i> Détails
                                    </a>
                                    @if (isSuperAdmin)
                                    {
                                        var canToggleSuspension = item.UserId != currentUserId && item.CurrentRole != "SuperAdmin";

                                        <a asp-action="Edit" asp-route-id="@item.UserId" class="btn btn-sm btn-warning">
                                            <i class="bi bi-pencil"></i> Modifier
                                        </a>
                                        @if (canToggleSuspension)
                                        {
                                            <form asp-action="ToggleSuspension" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.UserId" />
                                                <button type="submit" class="btn btn-sm @(item.IsSuspended ? "btn-success" : "btn-outline-danger")">
                                                    <i class="bi bi-lock"></i> @(item.IsSuspended ? "Réactiver" : "Suspendre")
                                                </button>
                                            </form>
                                        }
                                        <a asp-action="Delete" asp-route-id="@item.UserId" class="btn btn-sm btn-danger">
                                            <i class="bi bi-trash"></i> Supprimer
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body text-center py-5">
                <i class="bi bi-inbox empty-state-icon"></i>
                <h4 class="mt-3 text-muted">Aucun utilisateur trouvé</h4>
            </div>
        </div>
    }
</div>
