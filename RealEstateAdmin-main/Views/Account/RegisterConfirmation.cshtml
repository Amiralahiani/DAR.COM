@{
    ViewData["Title"] = "Confirmation d'inscription";
}

<div class="container">
    <div class="row justify-content-center py-5">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4 text-center">
                    <h2 class="mb-3 text-gradient">Confirmez votre email</h2>
                    @if (ViewBag.EmailSent == true)
                    {
                        <p class="mb-2">Un email de confirmation a été envoyé à :</p>
                        <p class="fw-bold mb-4">@ViewBag.Email</p>
                        <p class="text-muted mb-0">
                            Ouvrez le lien reçu pour activer votre compte avant de vous connecter.
                        </p>
                    }
                    else
                    {
                        <div class="alert alert-warning text-start mb-3" role="alert">
                            Le compte a été créé, mais l'email de confirmation n'a pas pu être envoyé.
                        </div>
                        <p class="mb-2">Adresse concernée :</p>
                        <p class="fw-bold mb-4">@ViewBag.Email</p>
                        <p class="text-muted mb-0">
                            Vérifiez la configuration SMTP puis renvoyez l'email de confirmation.
                        </p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
