@model RealEstateAdmin.Services.AgendaIndexData

@{
    ViewData["Title"] = "Agenda";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-gradient mb-0">
            <i class="bi bi-calendar3"></i> Agenda
        </h1>
        <a asp-action="Index" class="btn btn-outline-primary">
            <i class="bi bi-arrow-clockwise"></i> Actualiser
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="text-muted small">Aujourd'hui</div>
                    <div class="fs-4 fw-bold">@Model.TotalToday</div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="text-muted small">À venir</div>
                    <div class="fs-4 fw-bold">@Model.TotalUpcoming</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white">
            <h5 class="mb-0">Prochains créneaux</h5>
        </div>
        <div class="card-body p-0">
            @if (Model.UpcomingEvents.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Date / Heure</th>
                                <th>Type</th>
                                <th>Bien</th>
                                <th>Client</th>
                                <th>Assignation</th>
                                <th>Statut</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.UpcomingEvents)
                            {
                                <tr>
                                    <td class="fw-semibold">@item.Slot.ToString("dddd dd/MM/yyyy HH:mm")</td>
                                    <td>@item.EventType</td>
                                    <td>@item.BienTitre</td>
                                    <td>
                                        <div>@item.ClientName</div>
                                        @if (!string.IsNullOrWhiteSpace(item.ClientEmail))
                                        {
                                            <small class="text-muted">@item.ClientEmail</small>
                                        }
                                    </td>
                                    <td>@item.AssigneeName</td>
                                    <td>
                                        @if (item.Statut == "Accepté")
                                        {
                                            <span class="badge bg-success">Accepté</span>
                                        }
                                        else if (item.Statut == "Annulé")
                                        {
                                            <span class="badge bg-secondary">Annulé</span>
                                        }
                                        else if (item.Statut == "Refusé")
                                        {
                                            <span class="badge bg-danger">Refusé</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">Nouveau</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <a asp-action="Details" asp-route-id="@item.MessageId" class="btn btn-sm btn-outline-secondary me-1">
                                            Détails
                                        </a>
                                        @if (item.Statut == "Nouveau")
                                        {
                                            <form asp-action="Accept" asp-route-id="@item.MessageId" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-primary">Accepter</button>
                                            </form>
                                            <form asp-action="Refuse" asp-route-id="@item.MessageId" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Refuser</button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="p-4 text-muted">Aucun créneau à venir.</div>
            }
        </div>
    </div>

    @if (Model.PastEvents.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h6 class="mb-0">Historique récent</h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr>
                                <th>Date / Heure</th>
                                <th>Type</th>
                                <th>Bien</th>
                                <th>Client</th>
                                <th>Statut</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.PastEvents)
                            {
                                <tr>
                                    <td>@item.Slot.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@item.EventType</td>
                                    <td>@item.BienTitre</td>
                                    <td>@item.ClientName</td>
                                    <td>
                                        @if (item.Statut == "Accepté")
                                        {
                                            <span class="badge bg-success">Accepté</span>
                                        }
                                        else if (item.Statut == "Annulé")
                                        {
                                            <span class="badge bg-secondary">Annulé</span>
                                        }
                                        else if (item.Statut == "Refusé")
                                        {
                                            <span class="badge bg-danger">Refusé</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">Nouveau</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <a asp-action="Details" asp-route-id="@item.MessageId" class="btn btn-sm btn-outline-secondary me-1">
                                            Détails
                                        </a>
                                        @if (item.Statut == "Nouveau")
                                        {
                                            <form asp-action="Accept" asp-route-id="@item.MessageId" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-primary">Accepter</button>
                                            </form>
                                            <form asp-action="Refuse" asp-route-id="@item.MessageId" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Refuser</button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>
