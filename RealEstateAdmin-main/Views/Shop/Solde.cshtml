@model RealEstateAdmin.Services.ShopIndexData

@{
    ViewData["Title"] = "Biens en solde";
    var totalResults = Model.Biens.Count;
}

<div class="container shop-page">
    <div class="card border-0 shadow-sm shop-hero mb-3">
        <div class="card-body p-3 p-lg-4 d-flex flex-column flex-lg-row justify-content-between align-items-start align-items-lg-center gap-2">
            <div>
                <h1 class="text-white mb-1">
                    <i class="bi bi-tags"></i> Biens en solde
                </h1>
                <p class="mb-0 text-white-50">Retrouvez toutes les propriétés publiées avec une réduction active.</p>
            </div>
            <div class="d-flex align-items-center gap-3 flex-wrap">
                <span class="shop-result-pill">@totalResults bien@(totalResults > 1 ? "s" : "") en promotion</span>
                <a asp-controller="Shop" asp-action="Index" class="btn btn-light">
                    <i class="bi bi-arrow-left"></i> Retour au shop
                </a>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-3">
        <div class="card-header shop-filter-header">
            <h5 class="mb-0 text-white"><i class="bi bi-funnel"></i> Filtrer les promotions</h5>
        </div>
        <div class="card-body p-3">
            <form asp-action="Solde" method="get" class="row g-3">
                <div class="col-md-6 col-xl-3">
                    <label class="form-label">Localisation</label>
                    <input type="text" class="form-control" name="adresse" value="@Model.Filter.Adresse" placeholder="Ville, quartier..." />
                </div>
                <div class="col-md-6 col-xl-3">
                    <label class="form-label">Titre / mot-clÃ©</label>
                    <input type="text" class="form-control" name="titre" value="@Model.Filter.Titre" placeholder="Villa, Appartement..." />
                </div>
                <div class="col-md-6 col-xl-2">
                    <label class="form-label">Prix min</label>
                    <input type="number" class="form-control" name="prixMin" value="@Model.Filter.PrixMin" placeholder="0" />
                </div>
                <div class="col-md-6 col-xl-2">
                    <label class="form-label">Prix max</label>
                    <input type="number" class="form-control" name="prixMax" value="@Model.Filter.PrixMax" placeholder="Max" />
                </div>
                <div class="col-md-6 col-xl-2">
                    <label class="form-label">Surface min</label>
                    <input type="number" class="form-control" name="surfaceMin" value="@Model.Filter.SurfaceMin" placeholder="0" />
                </div>
                <div class="col-md-6 col-xl-2">
                    <label class="form-label">Surface max</label>
                    <input type="number" class="form-control" name="surfaceMax" value="@Model.Filter.SurfaceMax" placeholder="Max" />
                </div>
                <div class="col-md-6 col-xl-2">
                    <label class="form-label">Type</label>
                    <select class="form-select" name="type">
                        <option value="">Tous</option>
                        @foreach (var typeItem in Model.Types)
                        {
                            <option value="@typeItem" selected="@(Model.Filter.Type == typeItem)">@typeItem</option>
                        }
                    </select>
                </div>
                <div class="col-md-6 col-xl-2">
                    <label class="form-label">Statut</label>
                    <select class="form-select" name="statut">
                        <option value="">Tous</option>
                        @foreach (var statusItem in Model.Statuses)
                        {
                            <option value="@statusItem" selected="@(Model.Filter.Statut == statusItem)">@statusItem</option>
                        }
                    </select>
                </div>
                <div class="col-12 d-flex justify-content-end gap-2 mt-2">
                    <a asp-action="Solde" class="btn btn-outline-secondary btn-sm">Réinitialiser</a>
                    <button type="submit" class="btn btn-primary btn-sm px-3">
                        <i class="bi bi-search"></i> Filtrer
                    </button>
                </div>
            </form>
        </div>
    </div>

    @if (Model.Biens.Any())
    {
        <div class="row g-4">
            @foreach (var item in Model.Biens)
            {
                var imageUrl = !string.IsNullOrWhiteSpace(item.ImageUrl)
                    ? item.ImageUrl
                    : item.Images.FirstOrDefault()?.Url;
                var discountedPrice = item.Prix * (100 - item.DiscountPercent) / 100m;

                <div class="col-md-6 col-xl-4">
                    <article class="card border-0 shadow-sm h-100">
                        <div class="position-relative">
                            @if (!string.IsNullOrWhiteSpace(imageUrl))
                            {
                                <img src="@imageUrl" alt="@item.Titre" class="card-img-top" style="height: 240px; object-fit: cover;" />
                            }
                            else
                            {
                                <div class="d-flex align-items-center justify-content-center bg-light text-muted" style="height: 240px;">
                                    <i class="bi bi-image fs-1"></i>
                                </div>
                            }
                            <span class="badge bg-danger position-absolute top-0 end-0 m-3">-@item.DiscountPercent%</span>
                        </div>

                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                                <span class="badge rounded-pill bg-dark-subtle text-dark">@item.TypeTransaction</span>
                                <span class="badge rounded-pill @(item.StatutCommercial == "Vendu" ? "bg-secondary" : item.StatutCommercial == "Réservé" ? "bg-warning text-dark" : "bg-success")">
                                    @item.StatutCommercial
                                </span>
                            </div>

                            <h5 class="card-title">@item.Titre</h5>
                            <p class="text-muted small mb-3">
                                <i class="bi bi-geo-alt"></i> @(item.Adresse ?? "Adresse non précise")
                            </p>

                            <div class="mb-3">
                                <div class="text-muted text-decoration-line-through">@item.Prix.ToString("N2") DT</div>
                                <div class="fs-4 fw-bold text-danger">@discountedPrice.ToString("N2") DT</div>
                            </div>

                            <div class="d-flex flex-wrap gap-3 text-muted small mb-3">
                                <span><i class="bi bi-aspect-ratio"></i> @(item.Surface ?? 0) m²</span>
                                <span><i class="bi bi-door-closed"></i> @(item.NombrePieces ?? 0) piéces</span>
                            </div>

                            <p class="small mb-3">
                                Promotion de <strong>@item.DiscountPercent%</strong> sur ce bien.
                            </p>

                            <div class="mt-auto d-flex gap-2">
                                <a asp-controller="BienImmobilier" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">
                                    Voir les détails
                                </a>
                                <a asp-controller="Shop" asp-action="Index" asp-route-solde="1" asp-route-titre="@item.Titre" class="btn btn-primary btn-sm">
                                    Ouvrir dans le shop
                                </a>
                            </div>
                        </div>
                    </article>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body py-5 text-center">
                <i class="bi bi-tag fs-1 text-muted"></i>
                <h3 class="mt-3">Aucun bien en solde trouvÃ©</h3>
                <p class="text-muted mb-4">Ajustez vos filtres ou revenez plus tard pour consulter de nouvelles promotions.</p>
                <a asp-controller="Shop" asp-action="Index" class="btn btn-primary">
                    Voir tous les biens
                </a>
            </div>
        </div>
    }
</div>
