@model RealEstateAdmin.Models.ProfileViewModel
@{
    ViewData["Title"] = "Mon Profil";
    var perf = Model.Performance;
    var hasPerf = perf != null;
    var score = hasPerf ? perf!.ScoreGlobal : 0;
    var hasData = hasPerf && perf!.LastComputed != DateTime.MinValue;
    var badgeEmoji = score >= 80 ? "🥇" : (score >= 50 ? "🥈" : "🥉");
    var badgeText = score >= 80 ? "Excellent" : (score >= 50 ? "Bon" : "Moyen");
    var progressColor = score >= 80 ? "#22c55e" : (score >= 50 ? "#f59e0b" : "#ef4444");
}

<div class="container-fluid px-4 pt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h2 text-ink fw-bold mb-1">Mon Profil</h1>
            <p class="text-muted small mb-0">Gérez vos informations personnelles et votre compte</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Profile Summary Card (top) -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body d-flex align-items-center gap-4 p-4 flex-wrap">
            <div class="avatar-large flex-shrink-0">@(Model.Nom?[0].ToString().ToUpper() ?? "?")</div>
            <div>
                <h3 class="fw-bold mb-1">@Model.Nom</h3>
                <div class="badge bg-gold-soft text-gold px-3 py-2 rounded-pill mb-2">@Model.Role</div>
                <p class="text-muted small mb-0"><i class="bi bi-calendar3 me-1"></i> Membre depuis le @Model.DateInscription.ToString("dd MMMM yyyy")</p>
            </div>
        </div>
    </div>

    <!-- 2-column layout: left = form, right = performance -->
    <div class="row g-4 align-items-start">

        <!-- LEFT: Info form (60%) -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <ul class="nav nav-tabs card-header-tabs border-0" id="profileTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active fw-bold border-0 bg-transparent text-ink px-4 py-3" id="info-tab" data-bs-toggle="tab" data-bs-target="#info-pane" type="button" role="tab">Infos de base</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link fw-bold border-0 bg-transparent text-muted px-4 py-3" id="security-tab" data-bs-toggle="tab" data-bs-target="#security-pane" type="button" role="tab">Sécurité</button>
                        </li>
                    </ul>
                </div>
                <div class="card-body p-0">
                    <form asp-action="Update" method="post">
                        <div class="tab-content">
                            <div class="tab-pane fade show active p-4" id="info-pane" role="tabpanel" tabindex="0">
                                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>
                                <div class="row g-3">
                                    <div class="col-md-12">
                                        <label asp-for="Nom" class="form-label fw-bold small text-muted text-uppercase mb-2">@Html.DisplayNameFor(m => m.Nom)</label>
                                        <input asp-for="Nom" class="form-control form-control-modern" placeholder="Nom complet" />
                                        <span asp-validation-for="Nom" class="text-danger x-small"></span>
                                    </div>
                                    <div class="col-md-12">
                                        <label asp-for="Email" class="form-label fw-bold small text-muted text-uppercase mb-2">@Html.DisplayNameFor(m => m.Email)</label>
                                        <input asp-for="Email" class="form-control form-control-modern bg-light" readonly />
                                        <div class="form-text x-small mt-1">L'adresse email ne peut pas être modifiée ici.</div>
                                    </div>
                                    <div class="col-md-12">
                                        <label class="form-label fw-bold small text-muted text-uppercase mb-2">Rôle actuel</label>
                                        <input value="@Model.Role" class="form-control form-control-modern bg-light" readonly />
                                    </div>
                                </div>
                            </div>

                            <div class="tab-pane fade p-4" id="security-pane" role="tabpanel" tabindex="0">
                                <p class="text-muted small mb-4">Laissez les champs vides si vous ne souhaitez pas changer votre mot de passe.</p>
                                <div class="row g-3">
                                    <div class="col-md-12">
                                        <label asp-for="OldPassword" class="form-label fw-bold small text-muted text-uppercase mb-2">@Html.DisplayNameFor(m => m.OldPassword)</label>
                                        <input asp-for="OldPassword" class="form-control form-control-modern" placeholder="Ancien mot de passe" />
                                        <span asp-validation-for="OldPassword" class="text-danger x-small"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="NewPassword" class="form-label fw-bold small text-muted text-uppercase mb-2">@Html.DisplayNameFor(m => m.NewPassword)</label>
                                        <input asp-for="NewPassword" class="form-control form-control-modern" placeholder="Nouveau mot de passe" />
                                        <span asp-validation-for="NewPassword" class="text-danger x-small"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="ConfirmPassword" class="form-label fw-bold small text-muted text-uppercase mb-2">@Html.DisplayNameFor(m => m.ConfirmPassword)</label>
                                        <input asp-for="ConfirmPassword" class="form-control form-control-modern" placeholder="Confirmer" />
                                        <span asp-validation-for="ConfirmPassword" class="text-danger x-small"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="card-footer bg-light border-0 py-3 px-4 text-end">
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="bi bi-save me-2"></i> Enregistrer les modifications
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- RIGHT: Performance card (40%) — only for Admin -->
        @if (Model.Role == "Admin")
        {
            <div class="col-lg-5">
                <div class="perf-card">
                    <div class="perf-card-header">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="perf-title"><i class="bi bi-graph-up-arrow me-2"></i>Mes Performances</div>
                                @if (Model.Rank > 0)
                                {
                                    <div class="perf-rank-badge">Rang #@Model.Rank sur @Model.TotalAgents agents</div>
                                }
                                else
                                {
                                    <div class="perf-rank-badge">Classement en attente</div>
                                }
                            </div>
                            <div class="score-circle">
                                <span class="score-number">@score.ToString("0")</span>
                                <span class="score-denom">/100</span>
                            </div>
                        </div>

                        <div class="mt-3">
                            <div class="progress perf-progress-bar">
                                <div class="progress-bar" role="progressbar"
                                     style="width: @score.ToString("0")%; background: @progressColor; transition: width 1.2s ease;"></div>
                            </div>
                        </div>

                        <div class="perf-badge mt-2">
                            @badgeEmoji @badgeText
                        </div>
                    </div>

                    <div class="perf-card-body">
                        @if (!hasData)
                        {
                            <div class="text-center py-3">
                                <i class="bi bi-hourglass-split text-muted fs-3 mb-2 d-block"></i>
                                <div class="text-muted small">Aucune donnée calculée encore.<br>Cliquez sur "Recalculer" dans le tableau de bord.</div>
                            </div>
                        }
                        else
                        {
                            <div class="perf-criteria-list">
                                <div class="perf-criterion">
                                    <div class="criterion-left">
                                        <i class="bi bi-arrow-repeat text-primary"></i>
                                        <span>Taux de conversion</span>
                                    </div>
                                    <div class="criterion-right">
                                        <div class="criterion-bar-track">
                                            <div class="criterion-bar" style="width: @perf!.TauxConversion.ToString("0")%; background: #3b82f6;"></div>
                                        </div>
                                        <span class="criterion-value">@perf.TauxConversion.ToString("0.0")%</span>
                                    </div>
                                </div>
                                <div class="perf-criterion">
                                    <div class="criterion-left">
                                        <i class="bi bi-clock text-warning"></i>
                                        <span>Délai moyen vente</span>
                                    </div>
                                    <div class="criterion-right">
                                        <div class="criterion-bar-track">
                                            @{
                                                var delaiPct = Math.Min(100, (perf!.DelaiMoyenVente / 90.0) * 100);
                                            }
                                            <div class="criterion-bar" style="width: @delaiPct.ToString("0")%; background: #f59e0b;"></div>
                                        </div>
                                        <span class="criterion-value">@perf.DelaiMoyenVente.ToString("0") j</span>
                                    </div>
                                </div>
                                <div class="perf-criterion">
                                    <div class="criterion-left">
                                        <i class="bi bi-star-fill text-warning"></i>
                                        <span>Satisfaction client</span>
                                    </div>
                                    <div class="criterion-right">
                                        <div class="criterion-bar-track">
                                            <div class="criterion-bar" style="width: @((perf!.SatisfactionClient / 5.0 * 100).ToString("0"))%; background: #f59e0b;"></div>
                                        </div>
                                        <span class="criterion-value">@perf.SatisfactionClient.ToString("0.0") ★</span>
                                    </div>
                                </div>
                                <div class="perf-criterion">
                                    <div class="criterion-left">
                                        <i class="bi bi-house-check text-success"></i>
                                        <span>Biens vendus</span>
                                    </div>
                                    <div class="criterion-right">
                                        <span class="criterion-value fw-bold">@perf!.BiensVendus</span>
                                    </div>
                                </div>
                                <div class="perf-last-update text-end mt-2">
                                    Mis à jour : @perf!.LastComputed.ToString("dd/MM/yyyy")
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .avatar-large {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #3b82f6, #1d4ed8);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        font-weight: 800;
        box-shadow: 0 8px 20px rgba(59, 130, 246, 0.3);
    }

    .form-control-modern {
        padding: 0.75rem 1rem;
        border-radius: 12px;
        border: 1px solid rgba(12, 27, 34, 0.08);
        transition: all 0.2s;
    }

    .form-control-modern:focus {
        border-color: #b8872f;
        box-shadow: 0 0 0 0.25rem rgba(184, 135, 47, 0.1);
    }

    .bg-gold-soft { background-color: rgba(184, 135, 47, 0.1) !important; }
    .text-gold { color: #b8872f !important; }
    .x-small { font-size: 0.75rem; }

    .nav-tabs .nav-link.active {
        color: #b8872f !important;
        border-bottom: 3px solid #b8872f !important;
    }

    /* Performance Card */
    .perf-card {
        background: #0c1b22;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.25);
        border: 1px solid rgba(214, 165, 71, 0.2);
    }

    .perf-card-header {
        background: linear-gradient(135deg, #0f172a, #1e293b);
        padding: 1.5rem;
        border-bottom: 1px solid rgba(214, 165, 71, 0.15);
    }

    .perf-title {
        color: #d6a547;
        font-weight: 800;
        font-size: 1.05rem;
        letter-spacing: 0.5px;
    }

    .perf-rank-badge {
        color: rgba(255,255,255,0.5);
        font-size: 0.78rem;
        margin-top: 2px;
    }

    .score-circle {
        text-align: right;
    }

    .score-number {
        font-size: 2.2rem;
        font-weight: 900;
        color: #fff;
        line-height: 1;
    }

    .score-denom {
        font-size: 0.9rem;
        color: rgba(255,255,255,0.4);
        font-weight: 600;
    }

    .perf-progress-bar {
        height: 6px;
        border-radius: 4px;
        background: rgba(255,255,255,0.1);
        overflow: hidden;
    }

    .perf-badge {
        font-size: 0.82rem;
        font-weight: 700;
        color: #d6a547;
        letter-spacing: 0.5px;
    }

    .perf-card-body {
        padding: 1.25rem 1.5rem;
    }

    .perf-criteria-list {
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
    }

    .perf-criterion {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
    }

    .criterion-left {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: rgba(255,255,255,0.75);
        font-size: 0.85rem;
        min-width: 140px;
    }

    .criterion-right {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex: 1;
        justify-content: flex-end;
    }

    .criterion-bar-track {
        flex: 1;
        height: 4px;
        background: rgba(255,255,255,0.1);
        border-radius: 2px;
        overflow: hidden;
        max-width: 80px;
    }

    .criterion-bar {
        height: 100%;
        border-radius: 2px;
        transition: width 1s ease;
    }

    .criterion-value {
        color: #fff;
        font-weight: 700;
        font-size: 0.82rem;
        min-width: 45px;
        text-align: right;
    }

    .perf-last-update {
        font-size: 0.7rem;
        color: rgba(255,255,255,0.3);
    }
</style>
