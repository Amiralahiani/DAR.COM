@model IEnumerable<RealEstateAdmin.Models.BienImmobilier>

@{
    ViewData["Title"] = "Liste des biens immobiliers";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-gradient">
            <i class="bi bi-house-door"></i> @((User.IsInRole("Admin") || User.IsInRole("SuperAdmin")) ? "Biens Immobiliers" : "Mes biens immobiliers")
        </h1>
        <div class="d-flex gap-2">
            @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
            {
                <a asp-action="ExportCsv" class="btn btn-outline-primary">
                    <i class="bi bi-filetype-csv"></i> CSV
                </a>
                <a asp-action="ExportPdf" class="btn btn-outline-primary">
                    <i class="bi bi-file-earmark-pdf"></i> PDF
                </a>
            }
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Créer un nouveau bien
            </a>
            <a asp-action="Map" class="btn btn-outline-primary">
                <i class="bi bi-map"></i> Carte
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Formulaire de recherche -->
    <div class="card search-card mb-4">
        <div class="card-header">
            <h5 class="mb-0">
                <i class="bi bi-search"></i> Recherche avancée
            </h5>
        </div>
        <div class="card-body">
            <form asp-action="Index" method="get">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label for="titre" class="form-label">Titre</label>
                        <input type="text" class="form-control" id="titre" name="titre" value="@ViewBag.Titre" placeholder="Rechercher par titre..." />
                    </div>
                    <div class="col-md-3">
                        <label for="prixMin" class="form-label">Prix minimum (DT)</label>
                        <input type="number" class="form-control" id="prixMin" name="prixMin" value="@ViewBag.PrixMin" step="0.01" placeholder="0" />
                    </div>
                    <div class="col-md-3">
                        <label for="prixMax" class="form-label">Prix maximum (DT)</label>
                        <input type="number" class="form-control" id="prixMax" name="prixMax" value="@ViewBag.PrixMax" step="0.01" placeholder="999999" />
                    </div>
                    <div class="col-md-3">
                        <label for="surfaceMin" class="form-label">Surface minimum (m²)</label>
                        <input type="number" class="form-control" id="surfaceMin" name="surfaceMin" value="@ViewBag.SurfaceMin" placeholder="0" />
                    </div>
                    <div class="col-md-3">
                        <label for="typeTransaction" class="form-label">Type</label>
                        <select class="form-select" id="typeTransaction" name="typeTransaction">
                            <option value="">Tous</option>
                            @foreach (var type in (string[])ViewBag.TypeOptions)
                            {
                                <option value="@type" selected="@(ViewBag.TypeTransaction == type)">@type</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label for="statutCommercial" class="form-label">Statut commercial</label>
                        <select class="form-select" id="statutCommercial" name="statutCommercial">
                            <option value="">Tous</option>
                            @foreach (var status in (string[])ViewBag.CommercialStatusOptions)
                            {
                                <option value="@status" selected="@(ViewBag.StatutCommercial == status)">@status</option>
                            }
                        </select>
                    </div>
                    @if (ViewBag.IsAdmin == true)
                    {
                        <div class="col-md-3">
                            <label for="publicationStatus" class="form-label">Statut publication</label>
                            <select class="form-select" id="publicationStatus" name="publicationStatus">
                                <option value="">Tous</option>
                                @foreach (var pubStatus in (string[])ViewBag.PublicationStatusOptions)
                                {
                                    <option value="@pubStatus" selected="@(ViewBag.PublicationStatus == pubStatus)">@pubStatus</option>
                                }
                            </select>
                        </div>
                    }
                </div>
                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-search"></i> Rechercher
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-counterclockwise"></i> Réinitialiser
                    </a>
                </div>
            </form>
        </div>
    </div>

    @{
        var isAdmin = User.IsInRole("Admin") || User.IsInRole("SuperAdmin");
        var biensList = Model?.ToList() ?? new List<RealEstateAdmin.Models.BienImmobilier>();
        Func<RealEstateAdmin.Models.BienImmobilier, bool> isForSale = b =>
            string.IsNullOrWhiteSpace(b.TypeTransaction)
            || string.Equals(b.TypeTransaction, "A Vendre", System.StringComparison.OrdinalIgnoreCase)
            || string.Equals(b.TypeTransaction, "A Louer", System.StringComparison.OrdinalIgnoreCase);
        var biensAVendre = biensList.Where(isForSale).ToList();
        var biensAchetes = biensList
            .Where(b =>
                string.Equals(b.TypeTransaction, "Acheté", System.StringComparison.OrdinalIgnoreCase)
                || string.Equals(b.TypeTransaction, "Achete", System.StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    <!-- Liste des biens en cartes -->
    @if (biensList.Any())
    {
        if (isAdmin)
        {
            <div class="admin-bien-list d-flex flex-column gap-3">
                @foreach (var item in biensList)
                {
                    <article class="card border-0 shadow-sm admin-bien-row">
                        <div class="row g-0">
                            <div class="col-xl-3 col-lg-4">
                                <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none">
                                    <div class="admin-bien-media">
                                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                                        {
                                            <img src="@item.ImageUrl" alt="@item.Titre" />
                                        }
                                        else
                                        {
                                            <i class="bi bi-house-heart admin-bien-placeholder"></i>
                                        }
                                    </div>
                                </a>
                            </div>

                            <div class="col-xl-6 col-lg-5">
                                <div class="admin-bien-content">
                                    <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                        <h5 class="fw-bold mb-0">@Html.DisplayFor(modelItem => item.Titre)</h5>
                                        <div class="admin-bien-price">@item.Prix.ToString("N2") DT</div>
                                        @if (item.IsOnSale)
                                        {
                                            <span class="badge bg-danger">Solde -@item.DiscountPercent %</span>
                                        }
                                    </div>

                                    <div class="mb-2 d-flex gap-2 flex-wrap">
                                        <span class="badge @(item.PublicationStatus == "Publié" ? "bg-success" : item.PublicationStatus == "Refusé" ? "bg-danger" : "bg-warning text-dark")">
                                            @item.PublicationStatus
                                        </span>
                                        <span class="badge @(item.StatutCommercial == "Vendu" ? "bg-secondary" : item.StatutCommercial == "Réservé" ? "bg-warning text-dark" : "bg-success")">
                                            @item.StatutCommercial
                                        </span>
                                        <span class="badge bg-info text-dark">
                                            @item.TypeTransaction
                                        </span>
                                    </div>

                                    @if (!string.IsNullOrEmpty(item.Description))
                                    {
                                        <p class="text-muted mb-2 admin-bien-description">
                                            @Html.DisplayFor(modelItem => item.Description)
                                        </p>
                                    }

                                    <div class="alert alert-info py-2 px-3 mb-2">
                                        <i class="bi bi-person-circle"></i> <strong>Propriétaire:</strong> @(item.User?.Nom ?? item.User?.UserName ?? "N/A")
                                    </div>

                                    <div class="d-flex flex-wrap gap-3 mb-2 text-muted small">
                                        @if (item.Surface.HasValue)
                                        {
                                            <span><i class="bi bi-rulers text-primary"></i> @Html.DisplayFor(modelItem => item.Surface) m²</span>
                                        }
                                        @if (item.NombrePieces.HasValue)
                                        {
                                            <span><i class="bi bi-door-open text-primary"></i> @Html.DisplayFor(modelItem => item.NombrePieces) pièces</span>
                                        }
                                        @if (!string.IsNullOrEmpty(item.Adresse))
                                        {
                                            <span><i class="bi bi-geo-alt"></i> @Html.DisplayFor(modelItem => item.Adresse)</span>
                                        }
                                    </div>
                                </div>
                            </div>

                            <div class="col-xl-3 col-lg-3">
                                <div class="admin-bien-actions">
                                    <div class="d-flex gap-2">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-primary flex-fill">
                                            <i class="bi bi-eye"></i> Détails
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>

                                    @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                                    {
                                        <div class="dropdown">
                                            <button class="btn btn-sm btn-outline-primary dropdown-toggle w-100" type="button" data-bs-toggle="dropdown">
                                                Publication
                                            </button>
                                            <ul class="dropdown-menu w-100">
                                                <li>
                                                    <form asp-action="SetStatus" asp-route-id="@item.Id" method="post">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="status" value="En attente" />
                                                        <button type="submit" class="dropdown-item">En attente</button>
                                                    </form>
                                                </li>
                                                <li>
                                                    <form asp-action="SetStatus" asp-route-id="@item.Id" method="post">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="status" value="Publié" />
                                                        <button type="submit" class="dropdown-item">Publié</button>
                                                    </form>
                                                </li>
                                                <li>
                                                    <form asp-action="SetStatus" asp-route-id="@item.Id" method="post">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="status" value="Refusé" />
                                                        <button type="submit" class="dropdown-item text-danger">Refusé</button>
                                                    </form>
                                                </li>
                                            </ul>
                                        </div>
                                        <div class="dropdown">
                                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle w-100" type="button" data-bs-toggle="dropdown">
                                                Statut vente
                                            </button>
                                            <ul class="dropdown-menu w-100">
                                                <li>
                                                    <form asp-action="SetCommercialStatus" asp-route-id="@item.Id" method="post">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="commercialStatus" value="Disponible" />
                                                        <button type="submit" class="dropdown-item">Disponible</button>
                                                    </form>
                                                </li>
                                                <li>
                                                    <form asp-action="SetCommercialStatus" asp-route-id="@item.Id" method="post">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="commercialStatus" value="Réservé" />
                                                        <button type="submit" class="dropdown-item">Réservé</button>
                                                    </form>
                                                </li>
                                                <li>
                                                    <form asp-action="SetCommercialStatus" asp-route-id="@item.Id" method="post">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="commercialStatus" value="Vendu" />
                                                        <button type="submit" class="dropdown-item text-danger">Vendu</button>
                                                    </form>
                                                </li>
                                            </ul>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
        else
        {
            <h3 class="mt-4 mb-3">Biens à vendre</h3>
            @if (biensAVendre.Any())
            {
                <div class="row g-4">
                    @foreach (var item in biensAVendre)
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="property-card card h-100">
                                <div class="property-image">
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" alt="@item.Titre" class="cover-image-fill" />
                                    }
                                    else
                                    {
                                        <i class="bi bi-house-heart property-placeholder-icon"></i>
                                    }
                                </div>
                                <div class="card-body">
                                    <h5 class="card-title fw-bold">@Html.DisplayFor(modelItem => item.Titre)</h5>
                                    <div class="property-price">
                                        @item.Prix.ToString("N2") DT
                                    </div>
                                    <div class="mb-2 d-flex gap-2 flex-wrap">
                                        <span class="badge bg-success">En vente</span>
                                        <span class="badge @(item.PublicationStatus == "Publié" ? "bg-success" : item.PublicationStatus == "Refusé" ? "bg-danger" : "bg-warning text-dark")">
                                            @item.PublicationStatus
                                        </span>
                                        <span class="badge @(item.StatutCommercial == "Vendu" ? "bg-secondary" : item.StatutCommercial == "Réservé" ? "bg-warning text-dark" : "bg-success")">
                                            @item.StatutCommercial
                                        </span>
                                    </div>
                                    @if (!string.IsNullOrEmpty(item.Description))
                                    {
                                        <p class="card-text text-muted text-clamp-3">
                                            @Html.DisplayFor(modelItem => item.Description)
                                        </p>
                                    }
                                    <div class="property-details mb-3">
                                        @if (item.Surface.HasValue)
                                        {
                                            <div class="property-detail-item">
                                                <i class="bi bi-rulers text-primary"></i>
                                                <span>@Html.DisplayFor(modelItem => item.Surface) m²</span>
                                            </div>
                                        }
                                        @if (item.NombrePieces.HasValue)
                                        {
                                            <div class="property-detail-item">
                                                <i class="bi bi-door-open text-primary"></i>
                                                <span>@Html.DisplayFor(modelItem => item.NombrePieces) pièces</span>
                                            </div>
                                        }
                                    </div>
                                    @if (!string.IsNullOrEmpty(item.Adresse))
                                    {
                                        <p class="text-muted mb-3">
                                            <i class="bi bi-geo-alt"></i> @Html.DisplayFor(modelItem => item.Adresse)
                                        </p>
                                    }
                                    <div class="d-flex gap-2">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-primary flex-fill">
                                            <i class="bi bi-eye"></i> Détails
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="card mb-4">
                    <div class="card-body text-center py-4">
                        <h5 class="text-muted mb-0">Aucun bien en vente</h5>
                    </div>
                </div>
            }

            <h3 class="mt-5 mb-3">Biens achetés</h3>
            @if (biensAchetes.Any())
            {
                <div class="row g-4">
                    @foreach (var item in biensAchetes)
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="property-card card h-100">
                                <div class="property-image">
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" alt="@item.Titre" class="cover-image-fill" />
                                    }
                                    else
                                    {
                                        <i class="bi bi-house-heart property-placeholder-icon"></i>
                                    }
                                </div>
                                <div class="card-body">
                                    <h5 class="card-title fw-bold">@Html.DisplayFor(modelItem => item.Titre)</h5>
                                    <div class="property-price">
                                        @item.Prix.ToString("N2") DT
                                    </div>
                                    <div class="mb-2 d-flex gap-2 flex-wrap">
                                        <span class="badge bg-secondary">Acheté</span>
                                        <span class="badge @(item.PublicationStatus == "Publié" ? "bg-success" : item.PublicationStatus == "Refusé" ? "bg-danger" : "bg-warning text-dark")">
                                            @item.PublicationStatus
                                        </span>
                                        <span class="badge @(item.StatutCommercial == "Vendu" ? "bg-secondary" : item.StatutCommercial == "Réservé" ? "bg-warning text-dark" : "bg-success")">
                                            @item.StatutCommercial
                                        </span>
                                    </div>
                                    @if (!string.IsNullOrEmpty(item.Description))
                                    {
                                        <p class="card-text text-muted text-clamp-3">
                                            @Html.DisplayFor(modelItem => item.Description)
                                        </p>
                                    }
                                    <div class="property-details mb-3">
                                        @if (item.Surface.HasValue)
                                        {
                                            <div class="property-detail-item">
                                                <i class="bi bi-rulers text-primary"></i>
                                                <span>@Html.DisplayFor(modelItem => item.Surface) m²</span>
                                            </div>
                                        }
                                        @if (item.NombrePieces.HasValue)
                                        {
                                            <div class="property-detail-item">
                                                <i class="bi bi-door-open text-primary"></i>
                                                <span>@Html.DisplayFor(modelItem => item.NombrePieces) pièces</span>
                                            </div>
                                        }
                                    </div>
                                    @if (!string.IsNullOrEmpty(item.Adresse))
                                    {
                                        <p class="text-muted mb-3">
                                            <i class="bi bi-geo-alt"></i> @Html.DisplayFor(modelItem => item.Adresse)
                                        </p>
                                    }
                                    <div class="d-flex gap-2">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-primary flex-fill">
                                            <i class="bi bi-eye"></i> Détails
                                        </a>
                                        <form asp-action="MettreEnVente" asp-route-id="@item.Id" method="post" class="d-flex">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-success">
                                                <i class="bi bi-arrow-up-right-circle"></i> Mettre en vente
                                            </button>
                                        </form>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="card">
                    <div class="card-body text-center py-4">
                        <h5 class="text-muted mb-0">Aucun bien acheté</h5>
                    </div>
                </div>
            }
        }
    }
    else
    {
        <div class="card">
            <div class="card-body text-center py-5">
                <i class="bi bi-inbox empty-state-icon"></i>
                <h4 class="mt-3 text-muted">Aucun bien immobilier trouvé</h4>
                <p class="text-muted">Essayez de modifier vos critères de recherche</p>
                <a asp-action="Create" class="btn btn-primary mt-3">
                    <i class="bi bi-plus-circle"></i> Créer le premier bien
                </a>
            </div>
        </div>
    }
</div>
