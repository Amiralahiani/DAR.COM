@model RealEstateAdmin.Models.AgentPerformanceViewModel

@{
    ViewData["Title"] = "Détails performance agent";
    var rank = (int?)ViewBag.Rank ?? 0;
}

<div class="container-fluid px-4 py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="mb-1"><i class="bi bi-person-badge"></i> @Model.AgentName</h1>
            <p class="text-muted mb-0">
                Classement: <strong>#@rank</strong> | Score global: <strong>@Model.ScoreGlobal.ToString("0.0") / 100</strong>
            </p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Retour au ranking
        </a>
    </div>

    <div class="row g-3">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Biens vendus</div>
                    <div class="display-6 fw-bold">@Model.BiensVendus</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Valeur totale vendue</div>
                    <div class="display-6 fw-bold">@Model.ValeurTotaleVendue.ToString("N0") DT</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Ancienneté</div>
                    <div class="display-6 fw-bold">@Model.AncienneteMois mois</div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small mb-2">Taux de conversion</div>
                    <div class="fw-bold fs-4">@Model.TauxConversion.ToString("0.0")%</div>
                    <div class="progress mt-2" style="height: 8px;">
                        <div class="progress-bar bg-info" role="progressbar" style="width: @Model.TauxConversion.ToString("0")%" aria-valuenow="@Model.TauxConversion" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small mb-2">Taux paiement complet</div>
                    <div class="fw-bold fs-4">@Model.TauxPaiementComplet.ToString("0.0")%</div>
                    <div class="progress mt-2" style="height: 8px;">
                        <div class="progress-bar bg-success" role="progressbar" style="width: @Model.TauxPaiementComplet.ToString("0")%" aria-valuenow="@Model.TauxPaiementComplet" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Délai moyen de vente</div>
                    <div class="display-6 fw-bold">@Model.DelaiMoyenVente.ToString("0") j</div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Total visites</div>
                    <div class="display-6 fw-bold">@Model.TotalVisites</div>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4 text-muted small">
        Dernier recalcul: @(Model.LastComputed == DateTime.MinValue ? "N/A" : Model.LastComputed.ToString("dd/MM/yyyy HH:mm"))
    </div>
</div>
