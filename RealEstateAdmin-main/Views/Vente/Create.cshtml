@model RealEstateAdmin.Services.SalesCreateData

@{
    ViewData["Title"] = "Saisie manuelle d'une transaction";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-gradient mb-0">
            <i class="bi bi-journal-plus"></i> Saisie manuelle
        </h1>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Retour ventes
        </a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Input.BienImmobilierId" class="form-label"></label>
                        <select asp-for="Input.BienImmobilierId" class="form-select">
                            <option value="0">Sélectionner un bien</option>
                            @foreach (var bien in Model.Biens)
                            {
                                <option value="@bien.Value">@bien.Label</option>
                            }
                        </select>
                        <span asp-validation-for="Input.BienImmobilierId" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Input.Amount" class="form-label"></label>
                        <input asp-for="Input.Amount" type="number" step="0.01" min="0.01" class="form-control" />
                        <span asp-validation-for="Input.Amount" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Input.BuyerId" class="form-label"></label>
                        <select asp-for="Input.BuyerId" class="form-select">
                            <option value="">Non assigné</option>
                            @foreach (var user in Model.Users)
                            {
                                <option value="@user.Value">@user.Label</option>
                            }
                        </select>
                        <span asp-validation-for="Input.BuyerId" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Input.SellerId" class="form-label"></label>
                        <select asp-for="Input.SellerId" class="form-select">
                            <option value="">Non assigné</option>
                            @foreach (var user in Model.Users)
                            {
                                <option value="@user.Value">@user.Label</option>
                            }
                        </select>
                        <span asp-validation-for="Input.SellerId" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Input.PaymentMethod" class="form-label"></label>
                        <select asp-for="Input.PaymentMethod" class="form-select">
                            @foreach (var method in Model.PaymentMethods)
                            {
                                <option value="@method">@method</option>
                            }
                        </select>
                        <span asp-validation-for="Input.PaymentMethod" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Input.PaymentStatus" class="form-label"></label>
                        <select asp-for="Input.PaymentStatus" class="form-select">
                            @foreach (var status in Model.PaymentStatuses)
                            {
                                <option value="@status">@status</option>
                            }
                        </select>
                        <span asp-validation-for="Input.PaymentStatus" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Input.TransactionStatus" class="form-label"></label>
                        <select asp-for="Input.TransactionStatus" class="form-select">
                            @foreach (var status in Model.TransactionStatuses)
                            {
                                <option value="@status">@status</option>
                            }
                        </select>
                        <span asp-validation-for="Input.TransactionStatus" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Input.Notes" class="form-label"></label>
                        <textarea asp-for="Input.Notes" rows="4" class="form-control"></textarea>
                        <span asp-validation-for="Input.Notes" class="text-danger"></span>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle"></i> Enregistrer la transaction
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
