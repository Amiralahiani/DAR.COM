@model IEnumerable<RealEstateAdmin.Models.UserRoleViewModel>

@{
    ViewData["Title"] = "Gestion des rôles";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-gradient">
            <i class="bi bi-shield-check"></i> Gestion des rôles
        </h1>
        <span class="badge bg-primary fs-6">@Model.Count() utilisateur(s)</span>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model.Any())
    {
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-people"></i> Liste des utilisateurs et leurs rôles
                </h5>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>
                                <i class="bi bi-person"></i> Utilisateur
                            </th>
                            <th>
                                <i class="bi bi-envelope-at"></i> Email
                            </th>
                            <th>
                                <i class="bi bi-shield-check"></i> Rôle actuel
                            </th>
                            <th>
                                <i class="bi bi-lock"></i> État
                            </th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@user.UserName</strong>
                                </td>
                                <td>
                                    <a href="mailto:@user.Email" class="text-decoration-none">
                                        <i class="bi bi-envelope"></i> @user.Email
                                    </a>
                                </td>
                                <td>
                                    <span class="badge bg-@(user.CurrentRole == "SuperAdmin" ? "dark" : user.CurrentRole == "Admin" ? "danger" : "primary") fs-6">
                                        <i class="bi bi-@(user.CurrentRole == "SuperAdmin" || user.CurrentRole == "Admin" ? "shield-fill" : "person")"></i> @user.CurrentRole
                                    </span>
                                </td>
                                <td>
                                    @if (user.IsSuspended)
                                    {
                                        <span class="badge bg-danger">Suspendu</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Actif</span>
                                    }
                                </td>
                                <td class="text-end">
                                    @{
                                        var isSuperAdminRole = user.CurrentRole == "SuperAdmin";
                                        var isAdminRole = user.CurrentRole == "Admin";
                                        var canAssignRole = isAdminRole;
                                    }
                                    @if (canAssignRole)
                                    {
                                        <form asp-action="AssignRole" method="post" class="d-inline-flex align-items-center gap-2">
                                            <input type="hidden" name="userId" value="@user.UserId" />
                                            <select name="roleName" class="form-select form-select-sm field-width-auto">
                                                <option value="Admin" selected>Admin</option>
                                                <option value="SuperAdmin">SuperAdmin</option>
                                            </select>
                                            <button type="submit" class="btn btn-sm btn-primary">
                                                <i class="bi bi-check-circle"></i> Assigner
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Non modifiable</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card mt-4">
            <div class="card-body">
                <h5 class="card-title">
                    <i class="bi bi-info-circle"></i> Informations sur les rôles
                </h5>
                <div class="row">
                    <div class="col-md-6">
                        <div class="d-flex align-items-center mb-3">
                            <span class="badge bg-dark me-3 fs-6">SuperAdmin</span>
                            <span class="text-muted">Gestion complète des utilisateurs, rôles et supervision globale</span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex align-items-center mb-3">
                            <span class="badge bg-danger me-3 fs-6">Admin</span>
                            <span class="text-muted">Gestion opérationnelle de la plateforme</span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex align-items-center mb-3">
                            <span class="badge bg-primary me-3 fs-6">Utilisateur</span>
                            <span class="text-muted">Accès limité à ses propres biens immobiliers</span>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="alert alert-warning mb-0">
                            Règles: un <strong>Utilisateur</strong> ne peut pas être promu <strong>Admin</strong>.
                            Un compte <strong>Admin</strong> est créé directement par un <strong>SuperAdmin</strong>.
                            La promotion en <strong>SuperAdmin</strong> est autorisée uniquement pour un compte déjà <strong>Admin</strong>.
                            Un compte <strong>SuperAdmin</strong> n'est pas modifiable depuis cet écran.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body text-center py-5">
                <i class="bi bi-people empty-state-icon"></i>
                <h4 class="mt-3 text-muted">Aucun utilisateur</h4>
                <p class="text-muted">Aucun utilisateur n'est enregistré dans le système.</p>
            </div>
        </div>
    }
</div>
