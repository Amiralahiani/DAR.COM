@model RealEstateAdmin.Services.SalesCreateData

@{
    ViewData["Title"] = "Saisie manuelle d'une transaction";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-gradient mb-0">
            <i class="bi bi-journal-plus"></i> Saisie manuelle
        </h1>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Retour ventes
        </a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <form asp-action="Create" method="post" id="createSaleForm">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row g-3">
                    <div class="col-md-12">
                        <label asp-for="Input.BienImmobilierId" class="form-label">Sélectionner le Bien Immobilier</label>
                        <select asp-for="Input.BienImmobilierId" class="form-select" id="bienSelect">
                            <option value="0">--- Choisir un bien ---</option>
                            @foreach (var bien in Model.Biens)
                            {
                                <option value="@bien.Value">@bien.Label</option>
                            }
                        </select>
                        <span asp-validation-for="Input.BienImmobilierId" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Input.Amount" class="form-label">Prix de vente final (DT)</label>
                        <input asp-for="Input.Amount" type="number" step="0.01" min="0.01" class="form-control" id="prixInput" />
                        <span asp-validation-for="Input.Amount" class="text-danger"></span>
                        <div class="form-text text-muted" id="prixInitialLabel">Prix affiché : -</div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Surface (m²)</label>
                        <input type="text" id="surfaceInput" class="form-control bg-light" readonly />
                    </div>

                    <div class="col-12">
                        <label class="form-label">Adresse du bien</label>
                        <input type="text" id="adresseInput" class="form-control bg-light" readonly />
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Input.BuyerId" class="form-label">Acheteur (Client)</label>
                        <select asp-for="Input.BuyerId" class="form-select">
                            <option value="">-- Sélectionner l'acheteur --</option>
                            @foreach (var user in Model.Users)
                            {
                                <option value="@user.Value">@user.Label</option>
                            }
                        </select>
                        <span asp-validation-for="Input.BuyerId" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Input.SellerId" class="form-label">Vendeur (Propriétaire)</label>
                        <select asp-for="Input.SellerId" class="form-select" id="sellerSelect">
                            <option value="">-- Sélectionner le vendeur --</option>
                            @foreach (var user in Model.Users)
                            {
                                <option value="@user.Value">@user.Label</option>
                            }
                        </select>
                        <span asp-validation-for="Input.SellerId" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Input.AgentId" class="form-label">Agent responsable</label>
                        <select asp-for="Input.AgentId" class="form-select" id="agentSelect">
                            <option value="">-- Non assigné --</option>
                            @foreach (var user in Model.Users)
                            {
                                <option value="@user.Value">@user.Label</option>
                            }
                        </select>
                        <span asp-validation-for="Input.AgentId" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="Input.PaymentMethod" class="form-label">Mode initial</label>
                        <select asp-for="Input.PaymentMethod" class="form-select">
                            @foreach (var method in Model.PaymentMethods)
                            {
                                <option value="@method">@method</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="Input.PaymentStatus" class="form-label">Statut initial</label>
                        <select asp-for="Input.PaymentStatus" class="form-select">
                            @foreach (var status in Model.PaymentStatuses)
                            {
                                <option value="@status">@status</option>
                            }
                        </select>
                    </div>

                    <div class="col-12">
                        <label asp-for="Input.Notes" class="form-label">Notes ou conditions particulières</label>
                        <textarea asp-for="Input.Notes" rows="3" class="form-control" placeholder="Détails du contrat, échéances..."></textarea>
                        <span asp-validation-for="Input.Notes" class="text-danger"></span>
                    </div>
                </div>

                <div class="alert alert-info mt-4">
                    <i class="bi bi-info-circle"></i> 
                    Après l'enregistrement, vous pourrez <strong>générer le contrat formel</strong> et <strong>suivre les paiements</strong> depuis la fiche détail.
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-check-circle"></i> Valider et passer au contrat
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg">Annuler</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        $(document).ready(function() {
            $('#bienSelect').change(function() {
                var bienId = $(this).val();
                if (bienId && bienId != "0") {
                    $.get('/Vente/GetBienDetails/' + bienId, function(data) {
                        $('#prixInput').val(data.prix);
                        $('#prixInitialLabel').text('Prix affiché : ' + data.prix.toLocaleString() + ' DT');
                        $('#surfaceInput').val(data.surface + ' m²');
                        $('#adresseInput').val(data.adresse);
                        if (data.vendeurId) {
                            $('#sellerSelect').val(data.vendeurId);
                        }
                        if (data.agentId) {
                            $('#agentSelect').val(data.agentId);
                        }
                    });
                } else {
                    $('#prixInput').val('');
                    $('#prixInitialLabel').text('Prix affiché : -');
                    $('#surfaceInput').val('');
                    $('#adresseInput').val('');
                    $('#sellerSelect').val('');
                    $('#agentSelect').val('');
                }
            });
        });
    </script>
}
